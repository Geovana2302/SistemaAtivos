@model IEnumerable<SistemaAtivos.Models.Categoria>
@{
    ViewBag.Title = "Categorias";
    var isAdmin = Context.Session.GetString("UsuarioTipo") == "Admin";
    var empresaFiltro = ViewBag.EmpresaFiltro as int?;
}
<div class="page-header">
    <div><h4 class="page-title">Categorias</h4><p class="page-sub">@Model.Count() categoria(s)</p></div>
    <a asp-controller="Categoria" asp-action="Create" class="btn-purple">+ Nova categoria</a>
</div>
@if (isAdmin)
{
    <div style="display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;align-items:center">
        <a href="@Url.Action("Index","Categoria")" class="filter-chip @(empresaFiltro==null?"filter-chip-active":"")">Todas</a>
        @foreach (var emp in (IEnumerable<SistemaAtivos.Models.Empresa>)ViewBag.Empresas)
        {
            <a href="@Url.Action("Index","Categoria",new{empresaId=emp.Id})" class="filter-chip @(empresaFiltro==emp.Id?"filter-chip-active":"")">
                <span class="filter-dot" style="background:@emp.Cor"></span>@emp.Nome
            </a>
        }
    </div>
}
@if (!Model.Any())
{
    <div class="empty-state"><p>Nenhuma categoria cadastrada.</p></div>
}
else
{
    <div class="table-wrap"><table class="table-custom">
        <thead><tr>
            <th>Nome</th><th>Descrição</th>
            @if (isAdmin) { <th>Empresa</th> }
            <th>Ativos</th><th>Ações</th>
        </tr></thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td style="font-weight:500">
                        @if (!string.IsNullOrEmpty(cat.Icone)) { <i class="bi @cat.Icone" style="margin-right:6px;color:#534AB7"></i> }
                        @cat.Nome
                    </td>
                    <td>@(cat.Descricao ?? "—")</td>
                    @if (isAdmin) { <td>@(cat.Empresa?.Nome ?? "—")</td> }
                    <td>@cat.Ativos.Count</td>
                    <td>
                        <div class="dropdown" style="display:inline-block">
                            <button type="button" class="btn-xs-outline" data-bs-toggle="dropdown">&#8942;</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Categoria" asp-action="Edit" asp-route-id="@cat.Id">Editar</a></li>
                                <li>
                                    <form asp-controller="Categoria" asp-action="Delete" asp-route-id="@cat.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-delete-btn" onclick="return confirm('Excluir categoria?')">Excluir</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table></div>
}
