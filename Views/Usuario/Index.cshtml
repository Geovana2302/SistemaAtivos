@model IEnumerable<SistemaAtivos.Models.Usuario>
@{
    ViewBag.Title = "Usuários";
    var isAdmin = Context.Session.GetString("UsuarioTipo") == "Admin";
    var empresas = ViewBag.Empresas as List<SistemaAtivos.Models.Empresa>;
    var empresaFiltro = ViewBag.EmpresaFiltro as int?;
}
<div class="page-header">
    <div><h4 class="page-title">Usuários</h4><p class="page-sub">@Model.Count() usuário(s)</p></div>
    <a asp-controller="Usuario" asp-action="Create" class="btn-purple">+ Novo Usuário</a>
</div>
@if (isAdmin && empresas != null)
{
    <div style="display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap">
        <a href="@Url.Action("Index")" class="filter-chip @(empresaFiltro==null?"filter-chip-active":"")">Todos</a>
        @foreach (var emp in empresas)
        {
            <a href="@Url.Action("Index",new{empresaId=emp.Id})"
               class="filter-chip @(empresaFiltro==emp.Id?"filter-chip-active":"")">
                <span class="filter-dot" style="background:@emp.Cor"></span>@emp.Nome
            </a>
        }
    </div>
}
@if (!Model.Any())
{
    <div class="empty-state"><p>Nenhum usuário encontrado.</p></div>
}
else
{
    <div class="table-wrap"><table class="table-custom">
        <thead><tr>
            <th>Nome</th><th>E-mail</th><th>Perfil</th>
            @if (isAdmin) { <th>Empresa</th> }
            <th>Ações</th>
        </tr></thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td style="font-weight:500">@u.Nome</td>
                    <td>@u.Email</td>
                    <td>@(u.Perfil == Perfil.Admin ? "Administrador" : "Gestor de Empresa")</td>
                    @if (isAdmin)
                    {
                        <td>@if(u.Empresa!=null){<span class="filter-dot" style="background:@u.Empresa.Cor"></span>@u.Empresa.Nome}else{<text>-</text>}</td>
                    }
                    <td>
                        <a asp-controller="Usuario" asp-action="Edit" asp-route-id="@u.Id" class="btn-xs-outline">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table></div>
}
