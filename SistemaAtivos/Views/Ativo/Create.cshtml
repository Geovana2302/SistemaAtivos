@model SistemaAtivos.Models.Ativo
@{
    ViewBag.Title = "Novo Ativo";
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
}

<div class="page-header">
    <h4 class="page-title">Novo Ativo</h4>
</div>

<div class="form-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert-custom alert-danger-custom" })

        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.Nome, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.Nome, new { @class = "field-input", placeholder = "Nome do ativo", maxlength = "100" })
                @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "field-error" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.NumeroSerie, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.NumeroSerie, new { @class = "field-input", placeholder = "SN-001", maxlength = "50" })
                @Html.ValidationMessageFor(m => m.NumeroSerie, "", new { @class = "field-error" })
            </div>
        </div>
        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.Marca, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.Marca, new { @class = "field-input", maxlength = "50" })
                @Html.ValidationMessageFor(m => m.Marca, "", new { @class = "field-error" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.Modelo, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.Modelo, new { @class = "field-input", maxlength = "50" })
                @Html.ValidationMessageFor(m => m.Modelo, "", new { @class = "field-error" })
            </div>
        </div>
        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.CategoriaId, "Categoria", new { @class = "field-label" })
                @Html.DropDownList("CategoriaId", (SelectList)ViewBag.Categorias, "-- Selecione --", new { @class = "field-input" })
                @Html.ValidationMessageFor(m => m.CategoriaId, "", new { @class = "field-error" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.ColaboradorId, "Responsável", new { @class = "field-label" })
                @Html.DropDownList("ColaboradorId", (SelectList)ViewBag.Colaboradores, "-- Selecione --", new { @class = "field-input" })
                @Html.ValidationMessageFor(m => m.ColaboradorId, "", new { @class = "field-error" })
            </div>
        </div>
        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.DataAquisicao, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.DataAquisicao, "{0:yyyy-MM-dd}", new { @class = "field-input", type = "date" })
                @Html.ValidationMessageFor(m => m.DataAquisicao, "", new { @class = "field-error" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.Valor, new { @class = "field-label" })
                <input type="text" id="ValorDisplay" class="field-input"
                       placeholder="0,00" maxlength="15" inputmode="numeric"
                       autocomplete="off" />
                <input type="hidden" id="Valor" name="Valor" value="@Model.Valor" />
                @Html.ValidationMessageFor(m => m.Valor, "", new { @class = "field-error" })
            </div>
        </div>
        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.Status, new { @class = "field-label" })
                @Html.EnumDropDownListFor(m => m.Status, new { @class = "field-input" })
            </div>
            @if (isAdmin && ViewBag.EmpresaPreSelecionada == true)
            {
                @Html.HiddenFor(m => m.EmpresaId)
            }
            else if (isAdmin)
            {
                <div class="field-group">
                    <label class="field-label">Empresa</label>
                    @Html.DropDownList("EmpresaId", (SelectList)ViewBag.EmpresaSelectList, "-- Selecione --", new { @class = "field-input" })
                </div>
            }
        </div>
        <div class="field-group">
            @Html.LabelFor(m => m.Observacoes, new { @class = "field-label" })
            @Html.TextAreaFor(m => m.Observacoes, new { @class = "field-input", rows = "3", maxlength = "500" })
            @Html.ValidationMessageFor(m => m.Observacoes, "", new { @class = "field-error" })
        </div>

        <div class="form-actions">
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-cancel" })
            <button type="submit" class="btn-purple">Salvar ativo</button>
        </div>
    }
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            var display = $('#ValorDisplay');
            var hidden  = $('#Valor');

            // Formata número para exibição BR: 7000.50 -> "7.000,50"
            function formatarBR(num) {
                return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            // Se já houver valor ao carregar a página (edição / erro de validação)
            var inicial = parseFloat(hidden.val());
            if (!isNaN(inicial) && inicial > 0) {
                display.val(formatarBR(inicial));
            }

            display.on('input', function () {
                var raw = display.val().replace(/\D/g, '');
                if (raw === '') { hidden.val(''); display.val(''); return; }
                var num = parseInt(raw) / 100;
                display.val(formatarBR(num));
                // Valor para o POST sempre com ponto decimal
                hidden.val(num.toFixed(2));
            });
        });
    </script>
}