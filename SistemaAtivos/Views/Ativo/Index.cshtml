@model IEnumerable<SistemaAtivos.Models.Ativo>
@{
    ViewBag.Title = "Ativos";

    var tipoUsuario = Session["UsuarioTipo"]?.ToString();
    var isAdmin = (tipoUsuario == "Admin" || tipoUsuario == "Admin Chefe");
    var empresaIdLogada = Session["EmpresaId"] as int?;

    var empresas = ViewBag.Empresas as List<SistemaAtivos.Models.Empresa>;
    var empresaFiltro = ViewBag.EmpresaFiltro as int?;
    var ordemAtual = ViewBag.OrdemAtual as string ?? "recente";
    var buscaAtual = ViewBag.Busca as string ?? "";
    var paginaAtual = (int)(ViewBag.PaginaAtual ?? 1);
    var totalPaginas = (int)(ViewBag.TotalPaginas ?? 1);
    var totalItens = (int)(ViewBag.TotalItens ?? 0);
}

<div class="page-header">
    <div>
        <h4 class="page-title">Ativos</h4>
        <p class="page-sub" id="resultado-contador">
            @totalItens ativo(s) encontrado(s)@(string.IsNullOrEmpty(buscaAtual) ? "" : " para \"" + buscaAtual + "\"")
        </p>
    </div>
    @Html.ActionLink("+ Novo Ativo", "Create", null, new { @class = "btn-purple" })
</div>

<div style="margin-bottom:1rem">
    <div style="position:relative;max-width:520px">
        <i class="bi bi-search" style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#aaa;font-size:14px;pointer-events:none" aria-hidden="true"></i>
        <input type="text" id="busca-live"
               value="@buscaAtual"
               class="field-input"
               placeholder="Buscar por nome, série, categoria, empresa..."
               aria-label="Buscar ativo"
               autocomplete="off"
               style="padding-left:34px;padding-right:34px;height:38px" />
        <button id="btn-limpar-busca" type="button"
                aria-label="Limpar busca"
                style="display:none;position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:#aaa;font-size:16px;line-height:1;cursor:pointer">
            <i class="bi bi-x-circle-fill" aria-hidden="true"></i>
        </button>
    </div>
    <p id="sem-resultados" style="display:none;font-size:13px;color:#aaa;margin-top:8px">
        Nenhum ativo encontrado para "<span id="termo-sem-resultado"></span>"
    </p>
</div>

<div style="display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;align-items:center">
    <span style="font-size:12px;color:#888">Filtrar:</span>
    <a href="@Url.Action("Index", new { ordem = ordemAtual })"
       class="filter-chip @(empresaFiltro == null ? "filter-chip-active" : "")">Todas</a>
    @if (isAdmin && empresas != null)
    {
        foreach (var emp in empresas)
        {
            <a href="@Url.Action("Index", new { empresaId = emp.Id, ordem = ordemAtual })"
               class="filter-chip @(empresaFiltro == emp.Id ? "filter-chip-active" : "")"
               style="@(empresaFiltro == emp.Id ? "background:" + emp.Cor + ";color:#fff;border-color:" + emp.Cor : "")">
                <span class="filter-dot" style="background:@emp.Cor"></span>@emp.Nome
            </a>
        }
    }
    <span style="font-size:12px;color:#888;margin-left:12px">Ordenar:</span>
    <a href="@Url.Action("Index", new { empresaId = empresaFiltro, ordem = "recente" })"
       class="filter-chip @(ordemAtual == "recente" ? "filter-chip-active" : "")">Mais recente</a>
    <a href="@Url.Action("Index", new { empresaId = empresaFiltro, ordem = "antigo" })"
       class="filter-chip @(ordemAtual == "antigo" ? "filter-chip-active" : "")">Mais antigo</a>
    @if (isAdmin)
    {
        <a href="@Url.Action("Index", new { empresaId = empresaFiltro, ordem = "empresa" })"
           class="filter-chip @(ordemAtual == "empresa" ? "filter-chip-active" : "")">Por empresa</a>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <p style="font-size:32px;margin-bottom:8px">&#128230;</p>
        <p style="font-weight:500;color:#555;margin-bottom:4px">Nenhum ativo cadastrado</p>
        <p style="font-size:12px;color:#aaa;margin-bottom:1rem">Cadastre o primeiro ativo para começar.</p>
        @Html.ActionLink("+ Novo Ativo", "Create", null, new { @class = "btn-purple" })
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Categoria</th>
                    @if (isAdmin)
                    {
                        <th>Empresa</th>
                    }
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ativo in Model)
                {
                    var buscaData = (ativo.Nome + " " + ativo.NumeroSerie + " " + (ativo.Categoria?.Nome ?? "") + " " + (ativo.Empresa?.Nome ?? "")).ToLower();
                    <tr class="linha-ativo" data-busca="@buscaData">
                        <td>
                            <p style="font-weight:500;margin:0" class="campo-busca-nome">@ativo.Nome</p>
                            <p style="font-size:11px;color:#888;margin:0" class="campo-busca-serie">@ativo.NumeroSerie</p>
                        </td>
                        <td class="campo-busca-categoria">@(ativo.Categoria?.Nome ?? "-")</td>
                        @if (isAdmin)
                        {
                            <td>
                                @if (ativo.Empresa != null)
                                {
                                    <span class="filter-dot" style="background:@ativo.Empresa.Cor"></span>
                                    @ativo.Empresa.Nome
                                }
                                else
                                { <text>-</text>}
                            </td>
                        }
                        <td><span class="status-badge status-ativo">Ativo</span></td>
                        <td>
                            <div style="display:flex;gap:4px">
                                @Html.ActionLink("Ver", "Detalhes", new { id = ativo.Id }, new { @class = "btn-xs-outline" })
                                <div class="dropdown" style="display:inline-block">
                                    <button type="button" class="btn-xs-outline" data-toggle="dropdown">&#8942;</button>
                                    <ul class="dropdown-menu dropdown-menu-right">
                                        <li>@Html.ActionLink("Editar", "Edit", new { id = ativo.Id }, null)</li>

                                        @if (isAdmin || (tipoUsuario == "Gestor" && ativo.EmpresaId == empresaIdLogada))
                                        {
                                            <li>
                                                @using (Html.BeginForm("Delete", "Ativo", new { id = ativo.Id }, FormMethod.Post))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-delete-btn"
                                                            onclick="return confirm('Excluir este ativo?')">
                                                        Excluir
                                                    </button>
                                                }
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (totalPaginas > 1)
{
    <nav id="paginacao" aria-label="Navegação de páginas" style="display:flex;justify-content:center;gap:4px;margin-top:1.25rem;flex-wrap:wrap">
        @if (paginaAtual > 1)
        {
            <a href="@Url.Action("Index", new { empresaId = empresaFiltro, ordem = ordemAtual, busca = buscaAtual, pagina = paginaAtual - 1 })"
               class="btn-outline-sm" aria-label="Página anterior">&larr;</a>
        }
        @for (int p = 1; p <= totalPaginas; p++)
        {
            <a href="@Url.Action("Index", new { empresaId = empresaFiltro, ordem = ordemAtual, busca = buscaAtual, pagina = p })"
               class="btn-outline-sm @(p == paginaAtual ? "filter-chip-active" : "")"
               aria-label="Página @p" aria-current="@(p == paginaAtual ? "page" : null)">@p</a>
        }
        @if (paginaAtual < totalPaginas)
        {
            <a href="@Url.Action("Index", new { empresaId = empresaFiltro, ordem = ordemAtual, busca = buscaAtual, pagina = paginaAtual + 1 })"
               class="btn-outline-sm" aria-label="Próxima página">&rarr;</a>
        }
    </nav>
}

@section scripts {
<style>
    mark.busca-highlight {
        background: #FFF176;
        color: #1a1a1a;
        border-radius: 2px;
        padding: 0 1px;
        font-weight: 600;
    }
</style>
<script>
    (function () {
        var input      = document.getElementById('busca-live');
        var btnLimpar  = document.getElementById('btn-limpar-busca');
        var contador   = document.getElementById('resultado-contador');
        var semResult  = document.getElementById('sem-resultados');
        var termoSpan  = document.getElementById('termo-sem-resultado');
        var paginacao  = document.getElementById('paginacao');
        var linhas     = Array.from(document.querySelectorAll('.linha-ativo'));

        var totalOriginal = @totalItens;

        function escaparRegex(str) {
            return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }

        function destacar(elemento, termo) {
            if (!termo) {
                elemento.querySelectorAll('mark.busca-highlight').forEach(function (m) {
                    m.outerHTML = m.textContent;
                });
                return;
            }
            var campos = elemento.querySelectorAll('.campo-busca-nome, .campo-busca-serie, .campo-busca-categoria');
            campos.forEach(function (el) {
                var texto = el.textContent;
                var regex = new RegExp('(' + escaparRegex(termo) + ')', 'gi');
                el.innerHTML = texto.replace(regex, '<mark class="busca-highlight">$1</mark>');
            });
        }

        function filtrar() {
            var termo = input.value.trim().toLowerCase();

            btnLimpar.style.display = termo ? 'block' : 'none';

            if (!termo) {
                linhas.forEach(function (tr) {
                    tr.style.display = '';
                    destacar(tr, '');
                });
                contador.textContent = totalOriginal + ' ativo(s) encontrado(s)';
                semResult.style.display = 'none';
                if (paginacao) paginacao.style.display = '';
                return;
            }

            var visiveis = 0;
            linhas.forEach(function (tr) {
                var data = tr.getAttribute('data-busca') || '';
                if (data.indexOf(termo) !== -1) {
                    tr.style.display = '';
                    destacar(tr, termo);
                    visiveis++;
                } else {
                    tr.style.display = 'none';
                    destacar(tr, '');
                }
            });

            contador.textContent = visiveis + ' ativo(s) encontrado(s) para "' + input.value.trim() + '"';

            if (visiveis === 0) {
                semResult.style.display = 'block';
                termoSpan.textContent = input.value.trim();
            } else {
                semResult.style.display = 'none';
            }

            if (paginacao) paginacao.style.display = termo ? 'none' : '';
        }

        input.addEventListener('input', filtrar);

        btnLimpar.addEventListener('click', function () {
            input.value = '';
            input.focus();
            filtrar();
        });

        filtrar();
    })();
</script>
}