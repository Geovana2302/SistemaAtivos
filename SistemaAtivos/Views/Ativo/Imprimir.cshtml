@model SistemaAtivos.Models.Ativo
@{
    Layout = null;
    string urlAtivo = Url.Action("Detalhes", "Ativo", new { id = Model.Id }, Request.Url.Scheme);
    string urlQr    = Url.Action("QrCode",   "Ativo", new { id = Model.Id }, Request.Url.Scheme);
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Etiqueta - @Model.Nome</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f5f5f5;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 30px 20px;
            min-height: 100vh;
        }

        .toolbar {
            display: flex;
            gap: 10px;
            margin-bottom: 24px;
        }

        .btn-print {
            background: #534AB7;
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            font-weight: 600;
        }

        .btn-close {
            background: #fff;
            color: #444;
            border: 1px solid #ddd;
            padding: 10px 24px;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
        }

        .etiqueta {
            background: #fff;
            border: 2px solid #E5E4E0;
            border-radius: 12px;
            padding: 24px;
            width: 320px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }

        .etiqueta-empresa {
            font-size: 11px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            text-align: center;
        }

        .etiqueta-nome {
            font-size: 20px;
            font-weight: 700;
            color: #1a1a2e;
            text-align: center;
            line-height: 1.3;
        }

        .etiqueta-qr img {
            width: 180px;
            height: 180px;
            display: block;
        }

        .etiqueta-dados {
            width: 100%;
            border-top: 1px solid #eee;
            padding-top: 12px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .dado-row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
        }

        .dado-label { color: #888; }

        .dado-value {
            color: #333;
            font-weight: 600;
            text-align: right;
            max-width: 180px;
        }

        .etiqueta-url {
            font-size: 10px;
            color: #bbb;
            text-align: center;
            word-break: break-all;
        }

        .aviso-impressao {
            margin-top: 16px;
            font-size: 12px;
            color: #888;
            text-align: center;
        }

        .no-print { }

        @* regra de impressao sem @media para evitar conflito com Razor *@
    </style>
    <style type="text/css" media="print">
        @@page {
            margin: 0;
            size: auto;
        }
        body {
            background: #fff;
            padding: 10mm;
            justify-content: center;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .no-print { display: none !important; }
        .aviso-impressao { display: none !important; }
        .etiqueta {
            border: 1.5px solid #ccc;
            box-shadow: none;
            page-break-inside: avoid;
        }

    </style>
</head>
<body>

    <div class="toolbar no-print">
        <button class="btn-print" onclick="window.print()">Imprimir</button>
        <button class="btn-close" onclick="window.close()">Fechar</button>
    </div>

    <div class="etiqueta">

        @if (Model.Empresa != null)
        {
            <p class="etiqueta-empresa">@Model.Empresa.Nome</p>
        }

        <p class="etiqueta-nome">@Model.Nome</p>

        <div class="etiqueta-qr">
            <img src="@urlQr" alt="QR Code @Model.Nome" />
        </div>

        <div class="etiqueta-dados">
            @if (!string.IsNullOrEmpty(Model.NumeroSerie))
            {
                <div class="dado-row">
                    <span class="dado-label">N. Serie</span>
                    <span class="dado-value">@Model.NumeroSerie</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Marca) || !string.IsNullOrEmpty(Model.Modelo))
            {
                <div class="dado-row">
                    <span class="dado-label">Modelo</span>
                    <span class="dado-value">@(Model.Marca + " " + Model.Modelo)</span>
                </div>
            }
            @if (Model.Categoria != null)
            {
                <div class="dado-row">
                    <span class="dado-label">Categoria</span>
                    <span class="dado-value">@Model.Categoria.Nome</span>
                </div>
            }
            @if (Model.Colaborador != null)
            {
                <div class="dado-row">
                    <span class="dado-label">Responsavel</span>
                    <span class="dado-value">@Model.Colaborador.Nome</span>
                </div>
            }
        </div>

        <p class="etiqueta-url">@urlAtivo</p>
    </div>

    <p class="aviso-impressao no-print">
        Use o botao "Imprimir" acima ou Ctrl+P para gerar o PDF / enviar para impressora.
    </p>

    <script>
        window.onload = function () { window.print(); };
    </script>

</body>
</html>
