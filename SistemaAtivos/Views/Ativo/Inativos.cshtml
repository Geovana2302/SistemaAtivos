@model IEnumerable<SistemaAtivos.Models.Ativo>
@{
    ViewBag.Title = "Inativos";

    // 1. Pegamos as informações do usuário logado
    var tipoUsuario = Session["UsuarioTipo"]?.ToString();
    var isAdmin = (tipoUsuario == "Admin" || tipoUsuario == "Admin Chefe");
    var empresaIdLogada = Session["EmpresaId"] as int?;

    var empresas = ViewBag.Empresas as List<SistemaAtivos.Models.Empresa>;
    var empresaFiltro = ViewBag.EmpresaFiltro as int?;
    var ordemAtual = ViewBag.OrdemAtual as string ?? "recente";
}
<div class="page-header">
    <div>
        <h4 class="page-title">Inativos</h4>
        <p class="page-sub">@Model.Count() ativo(s) com status Inativo</p>
    </div>
</div>

<div class="filter-bar">
    <span class="filter-bar-label">Filtrar:</span>
    <a href="@Url.Action("Inativos", new { ordem = ordemAtual })"
       class="filter-chip @(empresaFiltro == null ? "filter-chip-active" : "")">Todas</a>
    @if (isAdmin && empresas != null)
    {
        foreach (var emp in empresas)
        {
            <a href="@Url.Action("Inativos", new { empresaId = emp.Id, ordem = ordemAtual })"
               class="filter-chip @(empresaFiltro == emp.Id ? "filter-chip-active" : "")">
                <span class="filter-dot" style="background:@emp.Cor" aria-hidden="true"></span>@emp.Nome
            </a>
        }
    }
    <span class="filter-bar-label-spaced">Ordenar:</span>
    <a href="@Url.Action("Inativos", new { empresaId = empresaFiltro, ordem = "recente" })"
       class="filter-chip @(ordemAtual == "recente" ? "filter-chip-active" : "")">Mais recente</a>
    <a href="@Url.Action("Inativos", new { empresaId = empresaFiltro, ordem = "antigo" })"
       class="filter-chip @(ordemAtual == "antigo" ? "filter-chip-active" : "")">Mais antigo</a>
    @if (isAdmin)
    {
        <a href="@Url.Action("Inativos", new { empresaId = empresaFiltro, ordem = "empresa" })"
           class="filter-chip @(ordemAtual == "empresa" ? "filter-chip-active" : "")">Por empresa</a>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <p class="empty-state-icon">&#9989;</p>
        <p class="empty-state-title">Nenhum ativo inativo</p>
        <p class="empty-state-sub">Todos os ativos estão com status Ativo.</p>
        @Html.ActionLink("Ver ativos", "Index", null, new { @class = "btn-purple" })
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Categoria</th>
                    @if (isAdmin)
                    {
                        <th>Empresa</th>
                    }
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ativo in Model)
                {
                    <tr>
                        <td>
                            <p class="td-nome-principal">@ativo.Nome</p>
                            <p class="td-nome-secundario">@ativo.NumeroSerie</p>
                        </td>
                        <td>@(ativo.Categoria?.Nome ?? "-")</td>
                        @if (isAdmin)
                        {
                            <td>
                                @if (ativo.Empresa != null)
                                {
                                    <span class="filter-dot" style="background:@ativo.Empresa.Cor" aria-hidden="true"></span>
                                    @ativo.Empresa.Nome
                                }
                                else
                                { <text>-</text>}
                            </td>
                        }
                        <td><span class="status-badge status-inativo">Inativo</span></td>
                        <td>
                            <div class="td-actions">
                                @Html.ActionLink("Ver", "Detalhes", new { id = ativo.Id }, new { @class = "btn-xs-outline" })
                                <div class="dropdown dropdown-inline">
                                    <button type="button" class="btn-xs-outline" data-toggle="dropdown">&#8942;</button>
                                    <ul class="dropdown-menu dropdown-menu-right">
                                        <li>@Html.ActionLink("Editar", "Edit", new { id = ativo.Id }, null)</li>

                                        @if (isAdmin || (tipoUsuario == "Gestor" && ativo.EmpresaId == empresaIdLogada))
                                        {
                                            <li>
                                                @using (Html.BeginForm("Delete", "Ativo", new { id = ativo.Id }, FormMethod.Post))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-delete-btn"
                                                            onclick="return confirm('Excluir este ativo?')">
                                                        Excluir
                                                    </button>
                                                }
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}