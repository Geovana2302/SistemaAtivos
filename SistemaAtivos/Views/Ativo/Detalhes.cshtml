@model SistemaAtivos.Models.Ativo
@{
    ViewBag.Title = Model.Nome;
}

<nav class="breadcrumb-custom">
    @if (Model.EmpresaId.HasValue)
    {
        @Html.ActionLink(Model.Empresa?.Nome ?? "Empresa", "Empresa", "Admin", new { id = Model.EmpresaId }, null)
        <span> / </span>
    }
    <span>@Model.Nome</span>
</nav>

<div class="detail-card">
    <div class="detail-header">
        <div>
            <h5 class="page-title" style="margin:0">@Model.Nome</h5>
            <p class="page-sub">@Model.Marca @Model.Modelo</p>
        </div>
        <span class="status-badge status-@Model.Status.ToString().ToLower()">@Model.Status</span>
    </div>

    <div class="detail-grid">
        <div class="detail-item"><span class="detail-label">N·mero de Sķrie</span><span class="detail-value">@(Model.NumeroSerie ?? "Ś")</span></div>
        <div class="detail-item"><span class="detail-label">Categoria</span><span class="detail-value">@(Model.Categoria?.Nome ?? "Ś")</span></div>
        <div class="detail-item"><span class="detail-label">Responsßvel</span><span class="detail-value">@(Model.Colaborador?.Nome ?? "Ś")</span></div>
        <div class="detail-item"><span class="detail-label">Data de AquisińŃo</span><span class="detail-value">@(Model.DataAquisicao?.ToString("dd/MM/yyyy") ?? "Ś")</span></div>
        <div class="detail-item"><span class="detail-label">Valor</span><span class="detail-value">@(Model.Valor.HasValue ? Model.Valor.Value.ToString("C2") : "Ś")</span></div>
        <div class="detail-item"><span class="detail-label">Empresa</span><span class="detail-value">@(Model.Empresa?.Nome ?? "Ś")</span></div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Observacoes))
    {
        <div class="detail-obs">
            <span class="detail-label">Observań§es</span>
            <p>@Model.Observacoes</p>
        </div>
    }

    <div class="detail-qr">
        <p class="detail-label" style="margin-bottom:8px">QR Code deste ativo</p>
        <img src="@Url.Action("QrCode", "Ativo", new { id = Model.Id })"
             alt="QR Code @Model.Nome"
             style="width:150px;height:150px;border:1px solid #E5E4E0;border-radius:8px;padding:8px" />
        <p style="font-size:11px;color:#aaa;margin-top:4px">/Ativo/Detalhes/@Model.Id</p>
    </div>

    <div class="detail-actions">
        @Html.ActionLink("? Editar", "Edit", "Ativo", new { id = Model.Id }, new { @class = "btn-purple" })
        @Html.ActionLink("+ ManutenńŃo", "Create", "Manutencao", new { ativoId = Model.Id }, new { @class = "btn-outline-sm" })
        @if (Model.EmpresaId.HasValue)
        {
            @Html.ActionLink("? Voltar", "Empresa", "Admin", new { id = Model.EmpresaId }, new { @class = "btn-cancel" })
        }
    </div>
</div>

@if (Model.Manutencoes != null && Model.Manutencoes.Any())
{
    <h6 class="section-title" style="margin-top:1.5rem">Hist¾rico de manutenń§es (@Model.Manutencoes.Count())</h6>
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Tipo</th>
                    <th>DescrińŃo</th>
                    <th>Status</th>
                    <th>Custo</th>
                    <th>Ań§es</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var man in Model.Manutencoes.OrderByDescending(m => m.Data))
                {
                    <tr>
                        <td style="white-space:nowrap">
                            <strong>@man.Data.ToString("dd/MM/yyyy")</strong>
                        </td>
                        <td>
                            <span class="acc-badge">@man.Tipo</span>
                        </td>
                        <td>
                            <p style="margin:0;font-size:13px">@man.Descricao</p>
                            @if (!string.IsNullOrEmpty(man.Fornecedor))
                            {
                                <p style="margin:0;font-size:11px;color:#888">@man.Fornecedor</p>
                            }
                        </td>
                        <td>
                            <span class="status-badge status-@man.Status.ToString().ToLower()">@man.Status</span>
                        </td>
                        <td style="white-space:nowrap">
                            @if (man.Custo.HasValue)
                            {
                                <span style="font-weight:500;color:#534AB7">@man.Custo.Value.ToString("C2")</span>
                            }
                            else if (man.ValorOrcamento.HasValue)
                            {
                                <span style="font-size:12px;color:#888">Orń: @man.ValorOrcamento.Value.ToString("C2")</span>
                            }
                            else
                            {
                                <span style="color:#ccc">Ś</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex;gap:4px">
                                @Html.ActionLink("Editar", "Edit", "Manutencao", new { id = man.Id }, new { @class = "btn-xs-outline" })
                                @using (Html.BeginForm("Delete", "Manutencao", new { id = man.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-xs-outline" onclick="return confirm('Deseja realmente excluir esta manutenńŃo?')" style="color:#d9534f;border-color:#d9534f">Excluir</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state" style="margin-top:1.5rem">
        <p>Nenhuma manutenńŃo registrada para este ativo.</p>
        @Html.ActionLink("+ Registrar ManutenńŃo", "Create", "Manutencao", new { ativoId = Model.Id }, new { @class = "btn-purple", style = "margin-top:8px" })
    </div>
}
