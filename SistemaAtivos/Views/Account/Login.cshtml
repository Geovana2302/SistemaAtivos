@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Sistema de Ativos</title>
    <link rel="stylesheet" href="~/Content/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/Site.css" />
    <style>
        html, body { height: 100%; margin: 0; }
        body { background: #F5F4F2; display: flex; align-items: center; justify-content: center; font-family: system-ui, sans-serif; }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-card">
            <div class="login-logo">A</div>
            <h4 class="login-title">Bem-vindo</h4>
            <p class="login-sub">Sistema de gestăo de ativos</p>

            @if (ViewBag.Erro != null)
            {
                <div class="alert-custom alert-danger-custom" style="margin-bottom:1rem">@ViewBag.Erro</div>
            }

            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="field-group">
                    <label class="field-label">E-mail</label>
                    <input name="email" type="email" class="field-input" placeholder="admin@sistema.com" autocomplete="email" />
                </div>
                <div class="field-group">
                    <label class="field-label">Senha</label>
                    <input name="senha" type="password" class="field-input" placeholder="••••••••" autocomplete="current-password" />
                </div>
                <button type="submit" class="btn-login">Entrar</button>
            }

            <p style="text-align:center;font-size:11px;color:#aaa;margin-top:1.5rem">
                Login padrăo: admin@sistema.com / admin123
            </p>
        </div>
    </div>
</body>
</html>
