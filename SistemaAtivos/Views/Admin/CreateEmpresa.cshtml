@model SistemaAtivos.Models.Empresa
@{
    ViewBag.Title = "Nova Empresa";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Nova Empresa</h4>
        <p class="page-sub">Preencha os dados para criar uma nova empresa</p>
    </div>
    <a href="@Url.Action("Dashboard", "Admin")" class="btn-outline-sm">&larr; Voltar</a>
</div>

<div class="form-card">
    @using (Html.BeginForm("CreateEmpresa", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        if (TempData["Erro"] != null)
        {
            <div class="alert-error-inline" role="alert">
                @TempData["Erro"]
            </div>
        }

        <div class="field-group">
            <label class="field-label" for="Nome">Nome da empresa <span style="color:red" aria-hidden="true">*</span></label>
            @Html.TextBoxFor(m => m.Nome, new { @class = "field-input", placeholder = "Ex: TechNova", required = "required" })
            @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "field-error" })
        </div>

        <div class="field-group">
            <label class="field-label" for="Cor">Cor da marca</label>
            @Html.TextBoxFor(m => m.Cor, new { @type = "color", @class = "field-input field-color", value = "#534AB7" })
            <small class="icone-hint">Escolha uma cor para identificar a empresa</small>
        </div>

        <div class="alert-warning-custom" role="note">
            Ap&oacute;s criar a empresa, acesse-a para cadastrar o primeiro gestor.
        </div>

        <div class="form-actions">
            @Html.ActionLink("Cancelar", "Dashboard", "Admin", null, new { @class = "btn-cancel" })
            <button type="submit" class="btn-purple">Criar Empresa</button>
        </div>
    }
</div>
