@model SistemaAtivos.Models.Empresa
@{
    ViewBag.Title = Model.Nome;
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
}
<nav class="breadcrumb-custom">
    @if (isAdmin)
    {@Html.ActionLink("Empresas", "Dashboard", "Admin") <span> / </span>}
    <span>@Model.Nome</span>
</nav>

<div class="empresa-header-bar">
    <div class="empresa-initials" style="background:@Model.Cor;width:48px;height:48px;font-size:20px;border-radius:10px" aria-hidden="true">
        @(Model.Nome.Length >= 2 ? Model.Nome.Substring(0, 2).ToUpper() : Model.Nome.ToUpper())
    </div>
    <div>
        <h5 class="page-title empresa-page-title">@Model.Nome</h5>
        <p class="page-sub empresa-page-sub">
            @{ var usr = Model.Usuarios.FirstOrDefault(); }
            @if (usr != null)
            {<text>@usr.Email</text>}
        </p>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card"><p class="stat-label">Categorias</p><p class="stat-value">@Model.Categorias.Count</p></div>
    <div class="stat-card"><p class="stat-label">Ativos</p><p class="stat-value">@Model.Ativos.Count(a => a.Status == SistemaAtivos.Models.StatusAtivo.Ativo)</p></div>
    <div class="stat-card"><p class="stat-label">Em Manuten&ccedil;&atilde;o</p><p class="stat-value">@Model.Ativos.Count(a => a.Status == SistemaAtivos.Models.StatusAtivo.EmManutencao)</p></div>
    <div class="stat-card"><p class="stat-label">Inativos</p><p class="stat-value">@Model.Ativos.Count(a => a.Status == SistemaAtivos.Models.StatusAtivo.Inativo)</p></div>
    <div class="stat-card"><p class="stat-label">Respons&aacute;veis</p><p class="stat-value">@Model.Colaboradores.Count</p></div>
    <div class="stat-card"><p class="stat-label">Gestores</p><p class="stat-value">@Model.Usuarios.Count(u => u.Perfil == SistemaAtivos.Models.Perfil.Gestor)</p></div>
</div>

<div class="section-header">
    <p class="section-title">Categorias</p>
    @Html.ActionLink("+ Categoria", "Create", "Categoria", new { empresaId = Model.Id }, new { @class = "btn-outline-sm" })
</div>

@if (!Model.Categorias.Any())
{
    <div class="empty-state">
        <p>Nenhuma categoria cadastrada ainda.</p>
        @Html.ActionLink("Criar primeira categoria", "Create", "Categoria", new { empresaId = Model.Id }, new { @class = "btn-purple" })
    </div>
}
else
{
    foreach (var cat in Model.Categorias)
    {
        var ativos = Model.Ativos.Where(a => a.CategoriaId == cat.Id).ToList();
        var collapseId = "cat-" + cat.Id;
        <div class="acc-card">
            <div class="acc-header-custom" data-acc-target="@collapseId">
                <div class="acc-left">
                    <span class="acc-dot" style="background:@Model.Cor"></span>
                    @if (!string.IsNullOrEmpty(cat.Icone))
                    {
                        <i class="bi @cat.Icone cat-icon" aria-hidden="true"></i>
                    }
                    <span class="acc-label">@cat.Nome</span>
                    <span class="acc-badge">@ativos.Count</span>
                </div>
                <div class="td-actions">
                    @Html.ActionLink("+", "Create", "Ativo", new { categoriaId = cat.Id, empresaId = Model.Id }, new { @class = "acc-action", title = "Adicionar ativo" })
                    <div class="dropdown dropdown-inline">
                        <button type="button" class="acc-action" data-toggle="dropdown" title="Op&ccedil;&otilde;es">&#8942;</button>
                        <ul class="dropdown-menu dropdown-menu-right">
                            <li>@Html.ActionLink("Editar categoria", "Edit", "Categoria", new { id = cat.Id }, null)</li>
                            <li>
                                @using (Html.BeginForm("Delete", "Categoria", new { id = cat.Id }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-delete-btn"
                                            onclick="return confirm('Excluir esta categoria e todos seus ativos?')">
                                        Excluir categoria
                                    </button>
                                }
                            </li>
                        </ul>
                    </div>
                    <span class="acc-chevron-custom">&#9660;</span>
                </div>
            </div>
            <div id="@collapseId" class="acc-body-custom">
                @if (!ativos.Any())
                {
                    <p class="acc-empty">Nenhum ativo nesta categoria.</p>
                }
                else
                {
                    foreach (var ativo in ativos)
                    {
                        <div class="ativo-row">
                            <div>
                                <p class="ativo-name">@ativo.Nome</p>
                                <p class="ativo-meta">
                                    @if (!string.IsNullOrEmpty(ativo.NumeroSerie))
                                    {<text>SN: @ativo.NumeroSerie &middot; </text>}
                                    <span class="status-badge status-@ativo.Status.ToString().ToLower()">@ativo.Status</span>
                                    @if (ativo.Colaborador != null)
                                    {<text> &middot; @ativo.Colaborador.Nome</text>}
                                </p>
                            </div>
                            <div class="td-actions">
                                @Html.ActionLink("Detalhes", "Detalhes", "Ativo", new { id = ativo.Id }, new { @class = "btn-xs-outline" })
                                <div class="dropdown dropdown-inline">
                                    <button type="button" class="btn-xs-outline" data-toggle="dropdown">&#8942;</button>
                                    <ul class="dropdown-menu dropdown-menu-right">
                                        <li>@Html.ActionLink("Editar", "Edit", "Ativo", new { id = ativo.Id }, null)</li>
                                        <li>
                                            @using (Html.BeginForm("Delete", "Ativo", new { id = ativo.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-delete-btn"
                                                        onclick="return confirm('Excluir este ativo?')">
                                                    Excluir
                                                </button>
                                            }
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
}

<div class="empresa-section-top">
        <p class="section-title">Respons&aacute;veis</p>
        <a href="@Url.Action("Create", "Colaborador", new { empresaId = Model.Id })" class="btn-outline-sm">+ Respons&aacute;vel</a>
    </div>

    @if (!Model.Colaboradores.Any())
    {
        <div class="empty-state">
        <p>Nenhum respons&aacute;vel cadastrado ainda.</p>
            <a href="@Url.Action("Create", "Colaborador", new { empresaId = Model.Id })" class="btn-purple">Criar primeiro respons&aacute;vel</a>
        </div>
    }
    else
    {
        foreach (var col in Model.Colaboradores)
        {
            var ativosCol = Model.Ativos.Where(a => a.ColaboradorId == col.Id).ToList();
            var colCollapseId = "resp-" + col.Id;
            <div class="acc-card">
                <div class="acc-header-custom" data-acc-target="@colCollapseId">
                    <div class="acc-left">
                        <span class="acc-dot" style="background:@Model.Cor"></span>
                        <span class="acc-label">@col.Nome</span>
                        @if (!string.IsNullOrEmpty(col.Cargo))
                        {
                            <span class="colaborador-cargo">@col.Cargo</span>
                        }
                        <span class="acc-badge">@ativosCol.Count ativo(s)</span>
                    </div>
                    <div class="td-actions">
                        <div class="dropdown dropdown-inline">
                            <button type="button" class="acc-action" data-toggle="dropdown" title="Op&ccedil;&otilde;es">&#8942;</button>
                            <ul class="dropdown-menu dropdown-menu-right">
                                <li>@Html.ActionLink("Editar", "Edit", "Colaborador", new { id = col.Id }, null)</li>
                                <li>
                                    @using (Html.BeginForm("Delete", "Colaborador", new { id = col.Id }, FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-delete-btn"
                                        onclick="return confirm('Excluir este respons\u00E1vel?')">
                                            Excluir
                                        </button>
                                    }
                                </li>
                            </ul>
                        </div>
                        <span class="acc-chevron-custom">&#9660;</span>
                    </div>
                </div>
                <div id="@colCollapseId" class="acc-body-custom">
                    @if (!string.IsNullOrEmpty(col.Email) || !string.IsNullOrEmpty(col.Telefone))
                    {
                        <p class="gestor-hint">
                            @if (!string.IsNullOrEmpty(col.Email)){<text>@col.Email</text>}
                            @if (!string.IsNullOrEmpty(col.Email) && !string.IsNullOrEmpty(col.Telefone)){<text> &middot; </text>}
                            @if (!string.IsNullOrEmpty(col.Telefone)){<text>@col.Telefone</text>}
                        </p>
                    }
                    @if (!ativosCol.Any())
                    {
                        <p class="acc-empty">Nenhum ativo sob responsabilidade.</p>
                    }
                    else
                    {
                        foreach (var ativo in ativosCol)
                        {
                            <div class="ativo-row">
                                <div>
                                    <p class="ativo-name">@ativo.Nome</p>
                                    <p class="ativo-meta">
                                        @if (!string.IsNullOrEmpty(ativo.NumeroSerie))
                                        {<text>SN: @ativo.NumeroSerie &middot; </text>}
                                        <span class="status-badge status-@ativo.Status.ToString().ToLower()">@ativo.Status</span>
                                        @if (ativo.Categoria != null)
                                        {<text> &middot; @ativo.Categoria.Nome</text>}
                                    </p>
                                </div>
                                <div class="td-actions">
                                    @Html.ActionLink("Detalhes", "Detalhes", "Ativo", new { id = ativo.Id }, new { @class = "btn-xs-outline" })
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }
</div>

<div class="empresa-section-top">
<div class="section-header">
    <p class="section-title">Gestores</p>
    <a href="@Url.Action("Create", "Usuario", new { empresaId = Model.Id })" class="btn-outline-sm">+ Gestor</a>
</div>

@if (!Model.Usuarios.Any(u => u.Perfil == SistemaAtivos.Models.Perfil.Gestor))
{
    <div class="empty-state">
        <p>Nenhum gestor cadastrado ainda.</p>
        <a href="@Url.Action("Create", "Usuario", new { empresaId = Model.Id })" class="btn-purple">Cadastrar primeiro gestor</a>
    </div>
}
else
{
    var usuarioLogadoId = (int)Session["UsuarioId"];
    foreach (var u in Model.Usuarios.Where(u => u.Perfil == SistemaAtivos.Models.Perfil.Gestor))
    {
        <div class="ativo-row">
            <div>
                <p class="ativo-name">
                    @u.Nome
                    @if (u.Id == usuarioLogadoId) { <span class="acc-badge">você</span> }
                </p>
                <p class="ativo-meta">@u.Email &middot; <span class="acc-badge">Gestor</span></p>
            </div>
            <div class="td-actions">
                @Html.ActionLink("Editar", "Edit", "Usuario", new { id = u.Id }, new { @class = "btn-xs-outline" })
                @if (u.Id != usuarioLogadoId)
                {
                    <button type="button" class="btn-xs-danger"
                            onclick="$('#modalExcluirGestor-@u.Id').modal('show')">
                        Excluir
                    </button>
                }
            </div>
        </div>
    }
}
</div>

@foreach (var u in Model.Usuarios.Where(u => u.Perfil == SistemaAtivos.Models.Perfil.Gestor))
{
    var logadoId2 = (int)Session["UsuarioId"];
    if (u.Id != logadoId2)
    {
        <div class="modal fade" id="modalExcluirGestor-@u.Id" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content modal-custom">
                    <div class="modal-body">
                        <h5 class="modal-title-custom">Excluir gestor</h5>
                        <p class="modal-sub-custom">
                            Tem certeza que deseja excluir <strong>@u.Nome</strong>? Esta ação não pode ser desfeita.
                        </p>
                        @using (Html.BeginForm("Delete", "Usuario", new { id = u.Id }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <div class="field-group">
                                <label class="field-label">Confirme sua senha <span style="color:red">*</span></label>
                                <input type="password" name="senhaConfirm" class="field-input"
                                       placeholder="Digite sua senha de acesso" required />
                            </div>
                            <div class="modal-actions">
                                <button type="button" class="btn-cancel" data-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn-danger">Confirmar exclusão</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@section scripts {
    <script>
        $(document).on('click', '.acc-header-custom', function (e) {
            if ($(e.target).closest('.dropdown, a, button, form').length) return;
            var id = $(this).data('acc-target');
            var body = $('#' + id);
            var chevron = $(this).find('.acc-chevron-custom');
            body.slideToggle(200, function () {
                chevron.html(body.is(':visible') ? '&#9660;' : '&#9654;');
            });
        });
    </script>
}