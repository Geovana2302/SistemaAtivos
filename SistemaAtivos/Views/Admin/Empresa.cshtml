@model SistemaAtivos.Models.Empresa
@{
    ViewBag.Title = Model.Nome;
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
}

<nav class="breadcrumb-custom">
    @if (isAdmin)
    {@Html.ActionLink("Empresas", "Dashboard", "Admin") <span> / </span>}
    <span>@Model.Nome</span>
</nav>

<div class="empresa-header-bar">
    <div class="empresa-initials" style="background:@Model.Cor;width:48px;height:48px;font-size:20px;border-radius:10px">
        @(Model.Nome.Length >= 2 ? Model.Nome.Substring(0, 2).ToUpper() : Model.Nome.ToUpper())
    </div>
    <div>
        <h5 class="page-title" style="margin:0">@Model.Nome</h5>
        <p class="page-sub" style="margin:0">
            @{ var usr = Model.Usuarios.FirstOrDefault(); }
            @if (usr != null)
            {<text>@usr.Email</text>}
        </p>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card"><p class="stat-label">Ativos</p><p class="stat-value">@Model.Ativos.Count(a => a.Status == SistemaAtivos.Models.StatusAtivo.Ativo)</p></div>
    <div class="stat-card"><p class="stat-label">Categorias</p><p class="stat-value">@Model.Categorias.Count</p></div>
    <div class="stat-card"><p class="stat-label">Em Manutencao</p><p class="stat-value">@Model.Ativos.Count(a => a.Status == SistemaAtivos.Models.StatusAtivo.EmManutencao)</p></div>
    <div class="stat-card"><p class="stat-label">Inativos</p><p class="stat-value">@Model.Ativos.Count(a => a.Status == SistemaAtivos.Models.StatusAtivo.Inativo)</p></div>
</div>

<div class="section-header">
    <p class="section-title">Categorias</p>
    @Html.ActionLink("+ Categoria", "Create", "Categoria", new { empresaId = Model.Id }, new { @class = "btn-outline-sm" })
</div>

@if (!Model.Categorias.Any())
{
    <div class="empty-state">
        <p>Nenhuma categoria cadastrada ainda.</p>
        @Html.ActionLink("Criar primeira categoria", "Create", "Categoria", new { empresaId = Model.Id }, new { @class = "btn-purple" })
    </div>
}
else
{
    foreach (var cat in Model.Categorias)
    {
        var ativos = Model.Ativos.Where(a => a.CategoriaId == cat.Id).ToList();
        var collapseId = "cat-" + cat.Id;
        <div class="acc-card">
            <div class="acc-header-custom" data-acc-target="@collapseId">
                <div class="acc-left">
                    <span class="acc-dot" style="background:@Model.Cor"></span>
                    <span class="acc-label">@cat.Nome</span>
                    <span class="acc-badge">@ativos.Count</span>
                </div>
                <div style="display:flex;align-items:center;gap:6px" onclick="event.stopPropagation()">
                    @Html.ActionLink("+", "Create", "Ativo", new { categoriaId = cat.Id, empresaId = Model.Id }, new { @class = "acc-action", title = "Adicionar ativo" })
                    <div class="dropdown" style="display:inline-block">
                        <button type="button" class="acc-action" data-toggle="dropdown" title="Opcoes">...</button>
                        <ul class="dropdown-menu dropdown-menu-right">
                            <li>@Html.ActionLink("Editar categoria", "Edit", "Categoria", new { id = cat.Id }, null)</li>
                            <li>
                                @using (Html.BeginForm("Delete", "Categoria", new { id = cat.Id }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-delete-btn"
                                            onclick="return confirm('Excluir esta categoria e todos seus ativos?')">
                                        Excluir categoria
                                    </button>
                                }
                            </li>
                        </ul>
                    </div>
                    <span class="acc-chevron-custom">&#9660;</span>
                </div>
            </div>
            <div id="@collapseId" class="acc-body-custom">
                @if (!ativos.Any())
                {
                    <p class="acc-empty">Nenhum ativo nesta categoria.</p>
                }
                else
                {
                    foreach (var ativo in ativos)
                    {
                        <div class="ativo-row">
                            <div>
                                <p class="ativo-name">@ativo.Nome</p>
                                <p class="ativo-meta">
                                    @if (!string.IsNullOrEmpty(ativo.NumeroSerie))
                                    {<text>SN: @ativo.NumeroSerie &middot; </text>}
                                    <span class="status-badge status-@ativo.Status.ToString().ToLower()">@ativo.Status</span>
                                    @if (ativo.Colaborador != null)
                                    {<text> &middot; @ativo.Colaborador.Nome</text>}
                                </p>
                            </div>
                            <div style="display:flex;gap:4px;align-items:center">
                                @Html.ActionLink("Detalhes", "Detalhes", "Ativo", new { id = ativo.Id }, new { @class = "btn-xs-outline" })
                                <div class="dropdown" style="display:inline-block">
                                    <button type="button" class="btn-xs-outline" data-toggle="dropdown">...</button>
                                    <ul class="dropdown-menu dropdown-menu-right">
                                        <li>@Html.ActionLink("Editar", "Edit", "Ativo", new { id = ativo.Id }, null)</li>
                                        <li>
                                            @using (Html.BeginForm("Delete", "Ativo", new { id = ativo.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-delete-btn"
                                                        onclick="return confirm('Excluir este ativo?')">
                                                    Excluir
                                                </button>
                                            }
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
}

@section scripts {
    <script>
        $(document).on('click', '.acc-header-custom', function (e) {
            if ($(e.target).closest('.dropdown, a, button, form').length) return;
            var id = $(this).data('acc-target');
            var body = $('#' + id);
            var chevron = $(this).find('.acc-chevron-custom');
            body.slideToggle(200, function () {
                chevron.html(body.is(':visible') ? '&#9660;' : '&#9654;');
            });
        });
    </script>
}