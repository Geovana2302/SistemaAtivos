@model SistemaAtivos.Models.Empresa
@{
    ViewBag.Title = Model.Nome;
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
}

<nav class="breadcrumb-custom">
    @if (isAdmin) { @Html.ActionLink("Empresas", "Dashboard", "Admin") <span> / </span> }
    <span>@Model.Nome</span>
</nav>

<div class="empresa-header-bar">
    <div class="empresa-initials" style="background:@Model.Cor;width:48px;height:48px;font-size:20px;border-radius:10px">
        @(Model.Nome.Length >= 2 ? Model.Nome.Substring(0, 2).ToUpper() : Model.Nome.ToUpper())
    </div>
    <div>
        <h5 class="page-title" style="margin:0">@Model.Nome</h5>
        <p class="page-sub" style="margin:0">
            @{ var usr = Model.Usuarios.FirstOrDefault(); }
            @if (usr != null) { <text>@usr.Email &middot; @usr.Tipo</text> }
        </p>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card"><p class="stat-label">Ativos</p><p class="stat-value">@Model.Ativos.Count</p></div>
    <div class="stat-card"><p class="stat-label">Categorias</p><p class="stat-value">@Model.Categorias.Count</p></div>
    <div class="stat-card"><p class="stat-label">Colaboradores</p><p class="stat-value">@Model.Colaboradores.Count</p></div>
    <div class="stat-card"><p class="stat-label">Manutençőes</p><p class="stat-value">@Model.Manutencoes.Count</p></div>
</div>

<div class="section-header">
    <p class="section-title">Categorias e ativos</p>
    <div style="display:flex;gap:6px">
        @Html.ActionLink("+ Ativo", "Create", "Ativo", null, new { @class = "btn-outline-sm" })
        @Html.ActionLink("+ Categoria", "Create", "Categoria", null, new { @class = "btn-outline-sm" })
        @Html.ActionLink("+ Colaborador", "Create", "Colaborador", null, new { @class = "btn-outline-sm" })
    </div>
</div>

@if (!Model.Categorias.Any())
{
    <div class="empty-state">
        <p>Nenhuma categoria cadastrada ainda.</p>
        @Html.ActionLink("Criar primeira categoria", "Create", "Categoria", null, new { @class = "btn-purple" })
    </div>
}
else
{
    <div class="accordion-custom" id="accordion">
        @foreach (var cat in Model.Categorias)
        {
            var ativos = Model.Ativos.Where(a => a.CategoriaId == cat.Id).ToList();
            var collapseId = "cat-" + cat.Id;
            <div class="acc-item">
                <div class="acc-header" data-toggle="collapse" data-target="#@collapseId" aria-expanded="true">
                    <div class="acc-left">
                        <span class="acc-dot" style="background:@Model.Cor"></span>
                        <span class="acc-label">@cat.Nome</span>
                        <span class="acc-badge">@ativos.Count ativo(s)</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px">
                        @Html.ActionLink("?", "Edit", "Categoria", new { id = cat.Id }, new { @class = "acc-action", title = "Editar categoria" })
                        @using (Html.BeginForm("Delete", "Categoria", new { id = cat.Id }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="acc-action acc-action-danger"
                                    onclick="return confirm('Excluir categoria @cat.Nome?')" title="Excluir">?</button>
                        }
                        <span class="acc-chevron">&#8964;</span>
                    </div>
                </div>
                <div id="@collapseId" class="collapse show">
                    <div class="acc-body">
                        @if (!ativos.Any())
                        {
                            <p class="acc-empty">Nenhum ativo nesta categoria.</p>
                        }
                        else
                        {
                            foreach (var ativo in ativos)
                            {
                                <div class="ativo-row">
                                    <div>
                                        <p class="ativo-name">@ativo.Nome</p>
                                        <p class="ativo-meta">
                                            @if (!string.IsNullOrEmpty(ativo.NumeroSerie)) { <text>SN: @ativo.NumeroSerie &middot; </text> }
                                            @ativo.Status
                                            @if (ativo.Colaborador != null) { <text> &middot; @ativo.Colaborador.Nome</text> }
                                        </p>
                                    </div>
                                    <div style="display:flex;gap:4px;align-items:center">
                                        @Html.ActionLink("Detalhes", "Detalhes", "Ativo", new { id = ativo.Id }, new { @class = "btn-xs-outline" })
                                        @Html.ActionLink("?", "Edit", "Ativo", new { id = ativo.Id }, new { @class = "btn-xs-outline", title = "Editar" })
                                        <a href="@Url.Action("QrCode", "Ativo", new { id = ativo.Id })" target="_blank" class="btn-xs-outline" title="QR Code">QR</a>
                                        @using (Html.BeginForm("Delete", "Ativo", new { id = ativo.Id }, FormMethod.Post, new { style = "display:inline" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-xs-danger"
                                                    onclick="return confirm('Excluir ativo @ativo.Nome?')" title="Excluir">?</button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
