@model IEnumerable<SistemaAtivos.Models.Usuario>
@{
    ViewBag.Title = "Administradores";
    var logadoId     = (int)Session["UsuarioId"];
    var isSuperAdmin = Session["IsSuperAdmin"] as bool? ?? false;
}

<div class="page-header">
    <div>
        <h4 class="page-title">Administradores do Sistema</h4>
        <p class="page-sub">@Model.Count() administrador(es) cadastrado(s)</p>
    </div>
    @if (isSuperAdmin)
    {
        @Html.ActionLink("+ Novo Administrador", "CreateAdmin", "Admin", null, new { @class = "btn-purple" })
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <p style="font-size:32px;margin-bottom:8px">&#128100;</p>
        <p style="font-weight:500;color:#555;margin-bottom:4px">Nenhum administrador cadastrado</p>
        @if (isSuperAdmin)
        {
            @Html.ActionLink("+ Novo Administrador", "CreateAdmin", "Admin", null, new { @class = "btn-purple" })
        }
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Tipo</th>
                    @if (isSuperAdmin) { <th style="width:80px">Acoes</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var admin in Model)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px">
                                <div style="width:32px;height:32px;border-radius:50%;background:#EEEDFE;color:#3C3489;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;flex-shrink:0">
                                    @admin.Nome.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <p style="font-weight:500;margin:0">@admin.Nome</p>
                                    @if (admin.Id == logadoId)
                                    {
                                        <span style="font-size:10px;background:#E1F5EE;color:#0F6E56;padding:1px 7px;border-radius:10px;font-weight:500">voce</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td style="color:#555">@admin.Email</td>
                        <td>
                            @if (admin.IsSuperAdmin)
                            {
                                <span class="user-badge badge-admin">Super Admin</span>
                            }
                            else
                            {
                                <span class="user-badge" style="background:#F5F4F2;color:#555;border:1px solid #E5E4E0">Admin</span>
                            }
                        </td>
                        @if (isSuperAdmin)
                        {
                            <td>
                                @if (!admin.IsSuperAdmin)
                                {
                                    <button type="button" class="btn-xs-danger"
                                            onclick="$('#modalDel-@admin.Id').modal('show')">
                                        Excluir
                                    </button>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    if (isSuperAdmin)
    {
        foreach (var admin in Model)
        {
            if (!admin.IsSuperAdmin)
            {
                <div class="modal fade" id="modalDel-@admin.Id" tabindex="-1" role="dialog">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content modal-custom">
                            <div class="modal-body">
                                <h5 class="modal-title-custom">Excluir administrador</h5>
                                <p class="modal-sub-custom">
                                    Tem certeza que deseja excluir <strong>@admin.Nome</strong>?
                                    Esta acao nao pode ser desfeita.
                                </p>
                                @using (Html.BeginForm("DeleteAdmin", "Admin", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@admin.Id" />
                                    <div class="field-group">
                                        <label class="field-label">Confirme sua senha <span style="color:red">*</span></label>
                                        <input type="password" name="senhaAdmin" class="field-input"
                                               placeholder="Digite sua senha de acesso" required />
                                    </div>
                                    <div class="modal-actions">
                                        <button type="button" class="btn-cancel" data-dismiss="modal">Cancelar</button>
                                        <button type="submit" class="btn-danger">Confirmar exclusao</button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }
}
