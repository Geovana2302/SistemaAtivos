<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Sistema de Ativos</title>

    <link rel="stylesheet" href="~/Content/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/Site.css?v=2" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style type="text/css" media="print">
        /* 1. Zerar a margem da página tira o espaço do cabeçalho/rodapé automático do navegador (Data, URL) */
        @@page {
            margin: 0;
        }

        /* 2. Adicionamos um espaçamento (padding) no body para o conteúdo não colar na beirada da folha física */
        body {
            padding: 15mm 15mm !important;
        }

        /* 3. Regra de ouro da impressão para forçar as cores exatas, ignorando bloqueios */
        *, *::before, *::after {
            -webkit-print-color-adjust: exact !important;
            color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    </style>
</head>
<body>
    @if (Session["UsuarioId"] != null)
    {
        var tipo = Session["UsuarioTipo"]?.ToString();
        var nome = Session["UsuarioNome"]?.ToString();
        var empId = Session["EmpresaId"];

        <nav class="navbar navbar-sistema" aria-label="Menu Principal">
            <div class="container-fluid">

                <div class="navbar-brand navbar-brand-sistema">
                    <div class="brand-logo" aria-hidden="true">A</div>
                    <span class="brand-name">Sistema Ativos</span>
                </div>

                <button class="navbar-toggler-sistema" type="button"
                        data-bs-toggle="collapse" data-bs-target="#menu-hamburguer"
                        aria-controls="menu-hamburguer" aria-expanded="false"
                        aria-label="Abrir menu de navegação">
                    <span class="navbar-toggler-icon-bar"></span>
                    <span class="navbar-toggler-icon-bar"></span>
                    <span class="navbar-toggler-icon-bar"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu-hamburguer">
                    <ul class="navbar-nav me-auto">
                        @if (tipo == "Admin")
                        {
                            <li class="nav-item">@Html.ActionLink("Empresas", "Dashboard", "Admin", null, new { @class = "nav-link", aria_label = "Acessar página de Empresas" })</li>
                            <li class="nav-item">@Html.ActionLink("Administradores", "Admins", "Admin", null, new { @class = "nav-link", aria_label = "Acessar página de Administradores" })</li>
                            <li class="nav-item">@Html.ActionLink("Ativos", "Index", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Ativos" })</li>
                            <li class="nav-item">@Html.ActionLink("Inativos", "Inativos", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Inativos" })</li>
                        }
                        else
                        {
                            <li class="nav-item">@Html.ActionLink("Minha Empresa", "Empresa", "Admin", new { id = empId }, new { @class = "nav-link", aria_label = "Acessar Minha Empresa" })</li>
                            <li class="nav-item">@Html.ActionLink("Ativos", "Index", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Ativos" })</li>
                            <li class="nav-item">@Html.ActionLink("Inativos", "Inativos", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Inativos" })</li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <div class="nav-user-info">
                                <span class="nav-user-name" aria-label="Usuário logado: @nome">@nome</span>
                                <span class="nav-user-badge @(tipo == "Admin" ? "badge-admin" : "badge-cliente")" aria-label="Nível de acesso: @tipo">@(tipo == "Admin" ? "Admin" : "Gestor")</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Sair", "Logout", "Account", null, new { @class = "btn-logout", aria_label = "Sair do sistema" })
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    }

    <div class="@(Session["UsuarioId"] != null ? "main-content" : "")">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert-custom alert-success-custom" role="alert" aria-live="polite">@TempData["Sucesso"]</div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert-custom alert-danger-custom" role="alert" aria-live="assertive">@TempData["Erro"]</div>
        }
        @RenderBody()
    </div>

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>

    <script>
        function verificarOrientacao() {
            // Verifica se a largura da tela é de celular (<= 768px)
            var isMobile = window.innerWidth <= 768;
            // Verifica se a altura é maior que a largura (Celular em pé)
            var isPortrait = window.innerHeight > window.innerWidth;

            if (isMobile && isPortrait) {
                alert("📱 Gire seu aparelho!\n\nEste sistema foi projetado para ser utilizado na horizontal (modo paisagem) para melhor visualização das tabelas.");
            }
        }

        // Executa assim que a página carrega
        $(document).ready(function () {
            verificarOrientacao();
        });

        // Executa sempre que o usuário virar o celular
        window.addEventListener("orientationchange", function () {
            // Pequeno atraso para dar tempo do navegador recalcular a largura
            setTimeout(verificarOrientacao, 200);
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
