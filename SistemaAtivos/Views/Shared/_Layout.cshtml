<!DOCTYPE html>
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Sistema de Ativos</title>

    <link rel="stylesheet" href="~/Content/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/Site.css?v=3" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style type="text/css" media="print">
        @@page { margin: 0; }
        body { padding: 15mm !important; }
        nav, footer, .no-print { display: none !important; }
        *, *::before, *::after {
            -webkit-print-color-adjust: exact !important;
            color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    </style>
</head>
<body>
    @if (Session["UsuarioId"] != null)
    {
        var tipo = Session["UsuarioTipo"]?.ToString();
        var nome = Session["UsuarioNome"]?.ToString();
        var empId = Session["EmpresaId"];

        <nav class="navbar navbar-expand-md" style="background:#fff; border-bottom:1px solid #E5E4E0;" aria-label="Menu Principal">
            <div class="container-fluid px-3">

                <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" href="#" aria-label="Sistema de Ativos">
                    <div style="width:30px;height:30px;background:#534AB7;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;font-weight:500;" aria-hidden="true">A</div>
                    <span style="font-size:14px;font-weight:500;color:#222;">Sistema Ativos</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#menu-principal"
                        aria-controls="menu-principal" aria-expanded="false"
                        aria-label="Abrir menu de navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu-principal">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        @if (tipo == "Admin")
                        {
                            <li class="nav-item">@Html.ActionLink("Empresas", "Dashboard", "Admin", null, new { @class = "nav-link", aria_label = "Acessar página de Empresas" })</li>
                            <li class="nav-item">@Html.ActionLink("Administradores", "Admins", "Admin", null, new { @class = "nav-link", aria_label = "Acessar página de Administradores" })</li>
                            <li class="nav-item">@Html.ActionLink("Ativos", "Index", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Ativos" })</li>
                            <li class="nav-item">@Html.ActionLink("Inativos", "Inativos", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Inativos" })</li>
                        }
                        else
                        {
                            <li class="nav-item">@Html.ActionLink("Minha Empresa", "Empresa", "Admin", new { id = empId }, new { @class = "nav-link", aria_label = "Acessar Minha Empresa" })</li>
                            <li class="nav-item">@Html.ActionLink("Ativos", "Index", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Ativos" })</li>
                            <li class="nav-item">@Html.ActionLink("Inativos", "Inativos", "Ativo", null, new { @class = "nav-link", aria_label = "Acessar lista de Inativos" })</li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2 mb-2 mb-md-0">
                        <li class="nav-item d-flex align-items-center gap-2" style="padding:0 4px">
                            <span style="font-size:13px;color:#555;" aria-label="Usuário logado: @nome">@nome</span>
                            <span class="@(tipo == "Admin" ? "badge-admin" : "badge-cliente")"
                                  style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;text-transform:uppercase;"
                                  aria-label="Nível de acesso: @tipo">
                                @(tipo == "Admin" ? "Admin" : "Gestor")
                            </span>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Sair", "Logout", "Account", null, new { @class = "btn-logout", aria_label = "Sair do sistema" })
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    }

    <div class="@(Session["UsuarioId"] != null ? "main-content" : "")">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert-custom alert-success-custom" role="alert" aria-live="polite">@TempData["Sucesso"]</div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert-custom alert-danger-custom" role="alert" aria-live="assertive">@TempData["Erro"]</div>
        }
        @RenderBody()
    </div>

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
