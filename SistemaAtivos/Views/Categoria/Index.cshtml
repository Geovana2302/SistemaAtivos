@model IEnumerable<SistemaAtivos.Models.Categoria>
@{
    ViewBag.Title = "Categorias";
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
    var empresaFiltro = ViewBag.EmpresaFiltro as int?;
}

<div class="page-header">
    <div>
        <h4 class="page-title">Categorias</h4>
        <p class="page-sub">@Model.Count() categoria(s)</p>
    </div>
    @Html.ActionLink("+ Nova categoria", "Create", null, new { @class = "btn-purple" })
</div>

@if (isAdmin)
{
    <div class="filter-bar" style="margin-bottom:1rem;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <a href="@Url.Action("Index", "Categoria")"
           class="filter-chip @(empresaFiltro == null ? "filter-chip-active" : "")">Todas</a>
        @foreach (var emp in (IEnumerable<SistemaAtivos.Models.Empresa>)ViewBag.Empresas)
        {
            <a href="@Url.Action("Index", "Categoria", new { empresaId = emp.Id })"
               class="filter-chip @(empresaFiltro == emp.Id ? "filter-chip-active" : "")">
                <span class="filter-dot" style="background:@emp.Cor"></span>
                @emp.Nome
            </a>
        }
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state"><p>Nenhuma categoria cadastrada.</p></div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Descrição</th>
                    @if (isAdmin) { <th>Empresa</th> }
                    <th>Ativos</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td style="font-weight:500">
                            @if (!string.IsNullOrEmpty(cat.Icone))
                            {
                                <i class="bi @cat.Icone" style="font-size:16px;margin-right:6px;color:#534AB7"></i>
                            }
                            @cat.Nome
                        </td>
                        <td>@(cat.Descricao ?? "—")</td>
                        @if (isAdmin) { <td>@(cat.Empresa?.Nome ?? "—")</td> }
                        <td>@cat.Ativos.Count</td>
                        <td>
                            <div style="display:flex;gap:4px">
                                <div class="dropdown" style="display:inline-block">
                                    <button type="button" class="btn-xs-outline" data-toggle="dropdown">&#8942;</button>
                                    <ul class="dropdown-menu dropdown-menu-right">
                                        <li>@Html.ActionLink("Editar", "Edit", new { id = cat.Id }, null)</li>
                                        <li>
                                            @using (Html.BeginForm("Delete", "Categoria", new { id = cat.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-delete-btn"
                                                        onclick="return confirm('Excluir categoria @cat.Nome?')">
                                                    Excluir
                                                </button>
                                            }
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
