@model SistemaAtivos.Models.Categoria
@{
    ViewBag.Title = "Editar Categoria";
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
    var cancelUrl = Model.EmpresaId.HasValue
        ? Url.Action("Empresa", "Admin", new { id = Model.EmpresaId })
        : Url.Action("Index", "Categoria");

    var icones = new[]
    {
        new { valor = "bi-laptop",          label = "Notebook" },
        new { valor = "bi-display",         label = "Monitor" },
        new { valor = "bi-printer",         label = "Impressora" },
        new { valor = "bi-phone",           label = "Celular" },
        new { valor = "bi-keyboard",        label = "Teclado" },
        new { valor = "bi-mouse",           label = "Mouse" },
        new { valor = "bi-hdd",             label = "HD/Storage" },
        new { valor = "bi-wifi",            label = "Rede/WiFi" },
        new { valor = "bi-camera",          label = "Camera" },
        new { valor = "bi-headset",         label = "Headset" },
        new { valor = "bi-tv",              label = "TV" },
        new { valor = "bi-router",          label = "Roteador" },
        new { valor = "bi-server",          label = "Servidor" },
        new { valor = "bi-tools",           label = "Ferramentas" },
        new { valor = "bi-briefcase",       label = "Escritorio" },
        new { valor = "bi-lamp",            label = "Movel" },
        new { valor = "bi-building",        label = "Infraestrutura" },
        new { valor = "bi-car-front",       label = "Veiculo" },
        new { valor = "bi-box-seam",        label = "Estoque" },
        new { valor = "bi-gear",            label = "Equipamento" },
        new { valor = "bi-shield-check",    label = "Seguranca" },
        new { valor = "bi-graph-up",        label = "Financeiro" },
        new { valor = "bi-people",          label = "RH" },
        new { valor = "bi-bookmark",        label = "Geral" },
    };
}

<div class="page-header">
    <h4 class="page-title">Editar Categoria</h4>
</div>

<div class="form-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.Icone)
        @Html.ValidationSummary(true, "", new { @class = "alert-custom alert-danger-custom" })

        <div class="field-group">
            @Html.LabelFor(m => m.Nome, new { @class = "field-label" })
            @Html.TextBoxFor(m => m.Nome, new { @class = "field-input" })
            @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "field-error" })
        </div>
        <div class="field-group">
            @Html.LabelFor(m => m.Descricao, new { @class = "field-label" })
            @Html.TextAreaFor(m => m.Descricao, new { @class = "field-input", rows = "3" })
        </div>

        <div class="field-group">
            <label class="field-label" id="label-icone">
                &Iacute;cone <span class="campo-opcional">(opcional)</span>
            </label>
            <div id="icone-grid" class="icone-grid" role="group" aria-labelledby="label-icone">
                @foreach (var ic in icones)
                {
                    <div class="icone-opt" data-valor="@ic.valor"
                         role="button" tabindex="0"
                         aria-label="@ic.label"
                         title="@ic.label">
                        <i class="bi @ic.valor" aria-hidden="true"></i>
                        <span>@ic.label</span>
                    </div>
                }
            </div>
            <p class="icone-hint">Clique para selecionar um &iacute;cone para esta categoria.</p>
        </div>

        if (isAdmin)
        {
            <div class="field-group">
                <label class="field-label">Empresa</label>
                @Html.DropDownList("EmpresaId", (SelectList)ViewBag.Empresas, "-- Selecione --", new { @class = "field-input" })
            </div>
        }

        <div class="form-actions">
            <a href="@cancelUrl" class="btn-cancel">Cancelar</a>
            <button type="submit" class="btn-purple">Salvar altera&ccedil;&otilde;es</button>
        </div>
    }
</div>

@section scripts {
<script>
    var selectedIcone = "@Model.Icone";

    function atualizarSelecao() {
        document.querySelectorAll('.icone-opt').forEach(function (el) {
            el.classList.toggle('selecionado', el.dataset.valor === selectedIcone);
        });
        document.getElementById('Icone').value = selectedIcone;
    }

    document.querySelectorAll('.icone-opt').forEach(function (el) {
        el.addEventListener('click', function () {
            selectedIcone = (selectedIcone === el.dataset.valor) ? '' : el.dataset.valor;
            atualizarSelecao();
        });
        el.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                selectedIcone = (selectedIcone === el.dataset.valor) ? '' : el.dataset.valor;
                atualizarSelecao();
            }
        });
    });

    atualizarSelecao();
</script>
}
