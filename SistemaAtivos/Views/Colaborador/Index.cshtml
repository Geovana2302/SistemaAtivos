@model IEnumerable<SistemaAtivos.Models.Colaborador>
@{
    ViewBag.Title = "Colaboradores";
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Colaboradores</h4>
        <p class="page-sub">@Model.Count() colaborador(es)</p>
    </div>
    @Html.ActionLink("+ Novo colaborador", "Create", null, new { @class = "btn-purple" })
</div>

@if (!Model.Any())
{
    <div class="empty-state"><p>Nenhum colaborador cadastrado.</p></div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Cargo</th>
                    <th>E-mail</th>
                    <th>Telefone</th>
                    @if (isAdmin) { <th>Empresa</th> }
                    <th>Ań§es</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var col in Model)
                {
                    <tr>
                        <td style="font-weight:500">@col.Nome</td>
                        <td>@(col.Cargo ?? "Ś")</td>
                        <td>@(col.Email ?? "Ś")</td>
                        <td>@(col.Telefone ?? "Ś")</td>
                        @if (isAdmin) { <td>@(col.Empresa?.Nome ?? "Ś")</td> }
                        <td>
                            <div style="display:flex;gap:4px">
                                <div class="dropdown" style="display:inline-block">
                                    <button type="button" class="btn-xs-outline" data-toggle="dropdown">&#8942;</button>
                                    <ul class="dropdown-menu dropdown-menu-right">
                                        <li>@Html.ActionLink("Editar", "Edit", new { id = col.Id }, null)</li>
                                        <li>
                                            @using (Html.BeginForm("Delete", "Colaborador", new { id = col.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-delete-btn"
                                                        onclick="return confirm('Excluir colaborador @col.Nome?')">
                                                    Excluir
                                                </button>
                                            }
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
