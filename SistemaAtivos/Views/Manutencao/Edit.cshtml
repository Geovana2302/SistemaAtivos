@model SistemaAtivos.Models.Manutencao
@{
    ViewBag.Title = "Editar Manutencao";
    var isAdmin = Session["UsuarioTipo"] != null && Session["UsuarioTipo"].ToString() == "Admin";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Editar Manutencao</h4>
    </div>
</div>

<div class="form-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert-custom alert-danger-custom" })
        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.EmpresaId)

        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.AtivoId, "Ativo / Equipamento", new { @class = "field-label" })
                @Html.DropDownList("AtivoId", (SelectList)ViewBag.AtivoId, "-- Selecione --", new { @class = "field-input", id = "ddlAtivo" })
                @Html.ValidationMessageFor(m => m.AtivoId, "", new { @class = "field-error" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.Data, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.Data, "{0:yyyy-MM-dd}", new { @class = "field-input", type = "date" })
                @Html.ValidationMessageFor(m => m.Data, "", new { @class = "field-error" })
            </div>
        </div>

        <div class="field-group">
            @Html.LabelFor(m => m.Descricao, "Descricao / Relato", new { @class = "field-label" })
            @Html.TextAreaFor(m => m.Descricao, new { @class = "field-input", rows = "4", placeholder = "Descreva o problema relatado pelo usuario" })
            @Html.ValidationMessageFor(m => m.Descricao, "", new { @class = "field-error" })
        </div>

        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.Custo, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.Custo, new { @class = "field-input money-mask", placeholder = "R$ 0,00" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.Fornecedor, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.Fornecedor, new { @class = "field-input", placeholder = "Fornecedor / Tecnico" })
            </div>
        </div>

        <div class="form-row-2">
            <div class="field-group">
                @Html.LabelFor(m => m.ProximaManutencao, new { @class = "field-label" })
                @Html.TextBoxFor(m => m.ProximaManutencao, "{0:yyyy-MM-dd}", new { @class = "field-input", type = "date" })
            </div>
            <div class="field-group">
                @Html.LabelFor(m => m.Tipo, new { @class = "field-label" })
                @Html.EnumDropDownListFor(m => m.Tipo, new { @class = "field-input" })
            </div>
        </div>

        if (isAdmin)
        {
            <div class="form-row-2">
                <div class="field-group">
                    @Html.LabelFor(m => m.Status, new { @class = "field-label" })
                    @Html.EnumDropDownListFor(m => m.Status, new { @class = "field-input" })
                </div>
                <div class="field-group">
                    @Html.LabelFor(m => m.ValorOrcamento, "Valor do Orcamento", new { @class = "field-label" })
                    @Html.TextBoxFor(m => m.ValorOrcamento, new { @class = "field-input money-mask", placeholder = "R$ 0,00" })
                </div>
            </div>

            <div class="field-group">
                @Html.LabelFor(m => m.DiagnosticoTecnico, new { @class = "field-label" })
                @Html.TextAreaFor(m => m.DiagnosticoTecnico, new { @class = "field-input", rows = "3", placeholder = "Diagnostico tecnico / Observacoes" })
            </div>

            <div class="field-group">
                <label class="field-label">Empresa</label>
                @Html.DropDownList("EmpresaId", (SelectList)ViewBag.EmpresaId, "-- Selecione --", new { @class = "field-input", disabled = "disabled" })
            </div>
        }

        <div class="form-actions">
            @if (Model?.AtivoId != null)
            {
                @Html.ActionLink("Cancelar", "Detalhes", "Ativo", new { id = Model.AtivoId }, new { @class = "btn-cancel" })
            }
            else
            {
                @Html.ActionLink("Cancelar", "Index", "Manutencao", null, new { @class = "btn-cancel" })
            }
            <button type="submit" class="btn-purple">Atualizar manutencao</button>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.money-mask').mask('#.##0,00', { reverse: true });
        });
    </script>
}
