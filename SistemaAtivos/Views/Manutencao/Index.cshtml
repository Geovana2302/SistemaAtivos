@model IEnumerable<SistemaAtivos.Models.Manutencao>
@{
    ViewBag.Title = "Manutenń§es";
    var isAdmin = Session["UsuarioTipo"]?.ToString() == "Admin";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Manutenń§es</h4>
        <p class="page-sub">@Model.Count() registro(s)</p>
    </div>
    @Html.ActionLink("+ Nova manutenńŃo", "Create", null, new { @class = "btn-purple" })
</div>

@if (!Model.Any())
{
    <div class="empty-state"><p>Nenhuma manutenńŃo registrada.</p></div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Ativo</th>
                    <th>Tipo</th>
                    <th>DescrińŃo</th>
                    <th>Custo</th>
                    @if (isAdmin) { <th>Empresa</th> }
                    <th>Ań§es</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var man in Model)
                {
                    <tr>
                        <td>@man.Data.ToString("dd/MM/yyyy")</td>
                        <td style="font-weight:500">@(man.Ativo?.Nome ?? "Ś")</td>
                        <td>
                            <span class="acc-badge">@man.Tipo</span>
                        </td>
                        <td>@man.Descricao</td>
                        <td>@(man.Custo.HasValue ? man.Custo.Value.ToString("C2") : "Ś")</td>
                        @if (isAdmin) { <td>@(man.Empresa?.Nome ?? "Ś")</td> }
                        <td>
                            @using (Html.BeginForm("Delete", "Manutencao", new { id = man.Id }, FormMethod.Post, new { style = "display:inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-xs-danger"
                                        onclick="return confirm('Excluir este registro de manutenńŃo?')">?</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
