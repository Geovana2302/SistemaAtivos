@model IEnumerable<SistemaAtivos.Models.Manutencao>
@{
    ViewBag.Title = "Minhas Manutenções";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Minhas Manutenções</h4>
        <p class="page-sub">Acompanhe o status dos seus equipamentos</p>
    </div>
    <div style="margin-left:auto">
        @Html.ActionLink("+ Solicitar Manutenção", "Create", null, new { @class = "btn-purple" })
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert-custom alert-success-custom">
        @TempData["Sucesso"]
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <p>Nenhuma manutenção registrada ainda.</p>
        @Html.ActionLink("+ Solicitar Manutenção", "Create", null, new { @class = "btn-purple", style = "margin-top:1rem" })
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Ativo</th>
                    <th>Descrição</th>
                    <th>Status</th>
                    <th>Orçamento</th>
                    <th>Data</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var man in Model)
                {
                    <tr>
                        <td>
                            <p style="font-weight:500;margin:0">@man.Ativo?.Nome</p>
                            <p style="font-size:11px;color:#888;margin:0">@man.Tipo</p>
                        </td>
                        <td>
                            <p style="margin:0;font-size:13px">@man.Descricao</p>
                            @if (!string.IsNullOrEmpty(man.DiagnosticoTecnico))
                            {
                                <details style="margin-top:4px">
                                    <summary style="cursor:pointer;font-size:11px;color:#534AB7">Ver diagnóstico</summary>
                                    <p style="font-size:12px;color:#666;margin:4px 0 0 0">@man.DiagnosticoTecnico</p>
                                </details>
                            }
                        </td>
                        <td>
                            @switch (man.Status)
                            {
                                case SistemaAtivos.Models.StatusManutencao.Aberto:
                                    <span class="status-badge" style="background:#f8d7da;color:#721c24">🆕 Aberto</span>
                                    break;
                                case SistemaAtivos.Models.StatusManutencao.EmOrcamento:
                                    <span class="status-badge" style="background:#fff3cd;color:#856404">💰 Em Orçamento</span>
                                    break;
                                case SistemaAtivos.Models.StatusManutencao.AguardandoAprovacao:
                                    <span class="status-badge" style="background:#d1ecf1;color:#0c5460">⏳ Aguarde Aprovação</span>
                                    break;
                                case SistemaAtivos.Models.StatusManutencao.Aprovado:
                                    <span class="status-badge" style="background:#d4edda;color:#155724">✅ Aprovado</span>
                                    break;
                                case SistemaAtivos.Models.StatusManutencao.EmConserto:
                                    <span class="status-badge" style="background:#cce5ff;color:#004085">🔧 Em Conserto</span>
                                    break;
                                case SistemaAtivos.Models.StatusManutencao.Concluido:
                                    <span class="status-badge" style="background:#e2e3e5;color:#383d41">✔ Concluído</span>
                                    break;
                                default:
                                    <span class="status-badge">@man.Status</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (man.ValorOrcamento.HasValue)
                            {
                                <strong style="color:#534AB7">@man.ValorOrcamento.Value.ToString("C2")</strong>
                            }
                            else
                            {
                                <span style="color:#ccc">Aguardando</span>
                            }
                        </td>
                        <td style="white-space:nowrap">
                            <span style="font-size:13px">@man.Data.ToString("dd/MM/yyyy")</span>
                            <br />
                            <span style="font-size:11px;color:#888">@man.TempoEsperaFormatado</span>
                        </td>
                        <td>
                            @if (man.Status == SistemaAtivos.Models.StatusManutencao.AguardandoAprovacao)
                            {
                                using (Html.BeginForm("Aprovar", "Manutencao", new { id = man.Id }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-purple" style="font-size:12px;padding:6px 12px" onclick="return confirm('Confirma a aprovação do orçamento de @man.ValorOrcamento?.ToString("C2")?')">
                                        ✅ Aprovar
                                    </button>
                                }
                            }
                            else
                            {
                                @Html.ActionLink("Ver detalhes", "Detalhes", "Ativo", new { id = man.AtivoId }, new { @class = "btn-xs-outline" })
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}